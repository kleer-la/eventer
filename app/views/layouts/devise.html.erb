<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= yield(:title) || t('title.untitled') %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= favicon_link_tag 'favicon.ico' %>
    <style>
      :root {
        --primary: #5c6bc0;
        --primary-dark: #3f51b5;
        --text: #1e2a33;
        --muted: #6b7280;
        --bg: #f5f5f5;
        --border: #e5e7eb;
        --danger: #f34541;
        --info: #00acec;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font: 16px/1.5 system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        color: var(--text);
        background: var(--bg);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
      }
      main.card {
        width: 100%;
        max-width: 380px;
        padding: 2rem;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      }
      h2 {
        margin: 0 0 1.5rem;
        font-size: 1.5rem;
        font-weight: 600;
      }
      form > div, form > p { margin-bottom: 1rem; }
      label {
        display: block;
        margin-bottom: 0.25rem;
        font-size: 0.9rem;
        color: var(--muted);
      }
      input[type="email"],
      input[type="password"],
      input[type="text"] {
        width: 100%;
        padding: 0.6rem 0.75rem;
        font-size: 1rem;
        border: 1px solid var(--border);
        border-radius: 4px;
        background: #fff;
      }
      input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(92,107,192,0.15);
      }
      input[type="checkbox"] {
        margin-right: 0.4rem;
        vertical-align: middle;
      }
      input[type="submit"], button[type="submit"] {
        width: 100%;
        padding: 0.65rem;
        font-size: 1rem;
        font-weight: 500;
        color: #fff;
        background: var(--primary);
        border: none;
        border-radius: 4px;
        cursor: pointer;
      }
      input[type="submit"]:hover, button[type="submit"]:hover {
        background: var(--primary-dark);
      }
      a {
        color: var(--primary);
        text-decoration: none;
        font-size: 0.9rem;
      }
      a:hover { text-decoration: underline; }
      .links { margin-top: 1.25rem; line-height: 1.8; }
      .alert {
        padding: 0.75rem 1rem;
        border-radius: 4px;
        margin-bottom: 1rem;
        font-size: 0.9rem;
      }
      .alert-info { background: #e0f7fa; color: #006064; }
      .alert-danger { background: #fde7e6; color: #b71c1c; }
      #error_explanation {
        padding: 0.75rem 1rem;
        background: #fde7e6;
        color: #b71c1c;
        border-radius: 4px;
        margin-bottom: 1rem;
        font-size: 0.9rem;
      }
      #error_explanation ul { margin: 0.25rem 0 0 1rem; padding: 0; }
    </style>
  </head>
  <body>
    <main class="card">
      <%= render '/commons/notice' %>
      <%= yield %>
    </main>
  </body>
</html>
